---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar';
import Footer from '../components/layout/Footer';
import { Button } from '@/components/ui/button';
import { motion } from 'framer-motion';
---

<Layout title="404 - Halaman Tidak Ditemukan">
    <Navbar client:load />
    <main class="min-h-screen flex items-center justify-center pt-20">
        <div class="text-center px-6">
            <h1 class="text-9xl font-black text-blue-600/20 mb-4">404</h1>
            <h2 class="text-4xl font-bold mb-4">Waduh! Halaman Hilang.</h2>
            <p class="text-foreground/60 mb-8 max-w-md mx-auto">
                Halaman yang Anda tuju kemungkinan tidak tersedia, telah dihapus, atau sedang dalam perbaikan.
            </p>
            <Button size="lg" className="rounded-full" asChild>
                <a href="/">Kembali ke Beranda</a>
            </Button>
        </div>
    </main>
    <Footer />
</Layout>
